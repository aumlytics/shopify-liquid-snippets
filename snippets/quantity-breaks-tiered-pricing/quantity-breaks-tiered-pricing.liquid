{% comment %}
  Quantity Breaks Tiered Pricing Display
  ======================================
  
  Displays volume discount tiers and updates pricing dynamically.
  
  Parameters:
    - product: (required) The product object
    - current_variant: (required) The selected variant
    - show_savings: (optional) Show savings calculator, default true
    - show_unit_price: (optional) Show per-unit price, default true
    - highlight_best_value: (optional) Highlight best tier, default true
    - tier_1_qty, tier_1_discount: First tier config
    - tier_2_qty, tier_2_discount: Second tier config  
    - tier_3_qty, tier_3_discount: Third tier config
    - currency_symbol: (optional) Currency symbol, default '$'
    - heading_text: (optional) Section heading
    - quantity_selector: (optional) CSS selector for quantity input
    
  Usage:
    {% render 'quantity-breaks-tiered-pricing',
      product: product,
      current_variant: product.selected_or_first_available_variant
    %}
{% endcomment %}

{%- comment -%} 
  === CONFIGURATION ===
  We prioritize metafields over parameters for flexibility.
  Shop owners can update tiers without code changes.
{%- endcomment -%}

{%- liquid
  # Set defaults for all parameters
  assign show_savings = show_savings | default: true
  assign show_unit_price = show_unit_price | default: true
  assign highlight_best_value = highlight_best_value | default: true
  assign currency_symbol = currency_symbol | default: '$'
  assign heading_text = heading_text | default: 'Buy More, Save More'
  assign quantity_selector = quantity_selector | default: '[name="quantity"]'
  
  # Default tier configuration (can be overridden by metafields or parameters)
  assign default_tier_1_qty = tier_1_qty | default: 5
  assign default_tier_1_discount = tier_1_discount | default: 10
  assign default_tier_2_qty = tier_2_qty | default: 10
  assign default_tier_2_discount = tier_2_discount | default: 15
  assign default_tier_3_qty = tier_3_qty | default: 25
  assign default_tier_3_discount = tier_3_discount | default: 20
  
  # Check for metafield-based pricing tiers
  # This allows per-product tier customization from the admin
  assign has_metafield_tiers = false
  if product.metafields.custom.quantity_breaks != blank
    assign has_metafield_tiers = true
    assign metafield_tiers = product.metafields.custom.quantity_breaks.value
  endif
  
  # Get the current variant's price in cents
  assign base_price_cents = current_variant.price
  assign base_price = base_price_cents | money_without_trailing_zeros
  assign compare_price_cents = current_variant.compare_at_price | default: base_price_cents
  
  # Check if product is available
  assign is_available = current_variant.available
-%}

{%- comment -%}
  Only render if the product is available and has valid pricing.
  No point showing bulk discounts for out-of-stock items.
{%- endcomment -%}
{%- if is_available and base_price_cents > 0 -%}

