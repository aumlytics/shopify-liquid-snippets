{% comment %}
  Estimated Delivery Date Display
  ================================
  Shows customers an estimated delivery date range based on:
  - Order processing time (business days)
  - Selected shipping method
  - Cutoff time for same-day processing
  - Holiday exclusions
  
  @param {Number} processing_days_min - Minimum processing business days (default: 1)
  @param {Number} processing_days_max - Maximum processing business days (default: 2)
  @param {String} shipping_methods - Comma-separated shipping options (id:min:max:label)
  @param {String} default_method - Pre-selected shipping method ID
  @param {Number} cutoff_hour - Hour (24h) cutoff for same-day processing (default: 14)
  @param {String} cutoff_timezone - Timezone for cutoff (default: 'America/New_York')
  @param {Boolean} show_countdown - Show order-by countdown (default: true)
  @param {Boolean} show_icon - Show delivery icon (default: true)
  @param {Boolean} show_method_selector - Allow method selection (default: true)
  @param {String} context - 'product' or 'cart' (default: 'product')
  @param {String} date_format - Date format preset (default: 'weekday_month_day')
  @param {String} locale - Locale for dates (default: 'en-US')
  @param {String} holidays - Comma-separated holidays (MM-DD or YYYY-MM-DD)
  @param {Boolean} exclude_weekends - Skip weekends (default: true)
  @param {String} wrapper_class - Additional wrapper CSS class
  @param {String} id_prefix - Prefix for IDs (default: 'edd')
{% endcomment %}

{% comment %} === PARAMETER DEFAULTS === {% endcomment %}
