```liquid
{% comment %}
  Infinite Scroll Collection Grid
  ================================
  Automatically loads more products as users scroll down collection pages.
  
  Parameters:
  - collection: Collection object (required)
  - products_per_page: Number of products per page (default: 12)
  - enable_infinite_scroll: Enable infinite scroll (default: true)
  - show_load_more_button: Show manual load button (default: false)
  - loading_threshold: Distance to trigger loading (default: '200px')
  - show_product_count: Show product counter (default: true)
  - product_card_snippet: Product card snippet name (default: 'product-card')
  - grid_classes: Additional grid CSS classes (default: '')
  - animate_new_products: Animate new products (default: true)
  
  Usage:
  {% render 'infinite-scroll-collection',
    collection: collection,
    products_per_page: 12,
    enable_infinite_scroll: true
  %}
{% endcomment %}

{% comment %} Set default values for all parameters {% endcomment %}
{% assign products_per_page = products_per_page | default: 12 %}
{% assign enable_infinite_scroll = enable_infinite_scroll | default: true %}
{% assign show_load_more_button = show_load_more_button | default: false %}
{% assign loading_threshold = loading_threshold | default: '200px' %}
{% assign show_product_count = show_product_count | default: true %}
{% assign product_card_snippet = product_card_snippet | default: 'product-card' %}
{% assign grid_classes = grid_classes | default: '' %}
{% assign animate_new_products = animate_new_products | default: true %}

{% comment %} 
  Paginate the collection - this creates the page structure that infinite scroll 
  will use to fetch additional products. The paginate object provides URLs for 
  next/previous pages that we'll fetch via JavaScript.
{% endcomment %}
{% paginate collection.products by products_per_page %}

{% comment %} 
  Scoped CSS - All styles are prefixed with .infinite-scroll to avoid 
  conflicts with existing theme styles. Using inline styles ensures the 
  snippet works immediately without requiring separate CSS file includes.
{% endcomment %}
<style>
  /* ========================================
     GRID LAYOUT
     ======================================== */
  .infinite-scroll {
    --infinite-scroll-columns: 4;
    --infinite-scroll-gap: 1.5rem;
    width: 100%;
  }
  
  .infinite-scroll__grid {
    display: grid;
    grid-template-columns: repeat(var(--infinite-scroll-columns), 1fr);
    gap: var(--infinite-scroll-gap);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  /* Responsive grid - 4 columns on desktop, 3 on tablet, 2 on mobile */
  @media screen and (max-width: 989px) {
    .infinite-scroll {
      --infinite-scroll-columns: 3;
    }
  }
  
  @media screen and (max-width: 749px) {
    .infinite-scroll {
      --infinite-scroll-columns: 2;
      --infinite-scroll-gap: 1rem;
    }
  }
  
  /* ========================================
     PRODUCT ITEMS
     ======================================== */
  .infinite-scroll__item {
    position: relative;
  }
  
  /* Animation for newly loaded products */
  .infinite-scroll__item--loading {
    opacity: 0;
    transform: translateY(20px);
  }
  
  .infinite-scroll__item--loaded {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  
  /* Respect user's motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .infinite-scroll__item--loading {
      transform: none;
    }
    .infinite-scroll__item--loaded {
      transition: opacity 0.2s ease;
    }
  }
  
  /* ========================================
     LOADING INDICATOR
     ======================================== */
  .infinite-scroll__loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    gap: 1rem;
  }
  
  .infinite-scroll__loader[hidden] {
    display: none;
  }
  
  /* Spinner animation */
  .infinite-scroll__spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(0, 0, 0, 0.1);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: infinite-scroll-spin 0.8s linear infinite;
  }
  
  @keyframes infinite-scroll-spin {
    to { transform: rotate(360deg); }
  }
  
  .infinite-scroll__loader-text {
    font-size: 0.875rem;
    color: rgba(0, 0, 0, 0.6);
  }
  
  /* ========================================
     LOAD MORE BUTTON
     ======================================== */
  .infinite-scroll__load-more {
    display: flex;
    justify-content: center;
    padding: 2rem 0;
  }
  
  .infinite-scroll__load-more[hidden] {
    display: none;
  }
  
  .infinite-scroll__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-size: 1rem;
    font-weight: 500;
    color: #fff;
    background-color: #000;
    border: 2px solid #000;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    min-width: 200px;
  }
  
  .infinite-scroll__button:hover,
  .infinite-scroll__button:focus {
    background-color: transparent;
    color: #000;
  }
  
  .infinite-scroll__button:focus {
    outline: 2px solid #000;
    outline-offset: 2px;
  }
  
  .infinite-scroll__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .infinite-scroll__button-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: infinite-scroll-spin 0.8s linear infinite;
  }
  
  .infinite-scroll__button-spinner[hidden] {
    display: none;
  }
  
  /* ========================================
     PRODUCT COUNT & STATUS
     ======================================== */
  .infinite-scroll__status {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }
  
  .infinite-scroll__count {
    font-size: 0.875rem;
    color: rgba(0, 0, 0, 0.7);
  }
  
  .infinite-scroll__count-current {
    font-weight: 600;
  }
  
  /* ========================================
     SCROLL SENTINEL
     The invisible element that triggers loading when scrolled into view.
     Using a dedicated sentinel is more reliable than observing the last product.
     ======================================== */
  .infinite-scroll__sentinel {
    height: 1px;
    width: 100%;
    visibility: hidden;
    pointer-events: none;
  }
  
  /* ========================================
     END MESSAGE
     ======================================== */
  .infinite-scroll__end {
    text-align: center;
    padding: 2rem;
    color: rgba(0, 0, 0, 0.6);
    font-size: 0.875rem;
  }
  
  .infinite-scroll__end[hidden] {
    display: none;
  }
  
  /* ========================================
     ERROR STATE
     ======================================== */
  .infinite-scroll__error {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
  }
  
  .infinite-scroll__error[hidden] {
    display: none;
  }
  
  .infinite-scroll__error-text {
    color: #c41e3a;
    font-size: 0.875rem;
  }
  
  .infinite-scroll__retry {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    background: transparent;
    border: 1px solid currentColor;
    border-radius: 4px;
    cursor: pointer;
  }
  
  /* ========================================
     TRADITIONAL PAGINATION FALLBACK
     For users without JavaScript or older browsers
     ======================================== */
