    }

    /* Warning state - visual urgency when time is running low */
    .cart-reserved-timer.is-warning {
      background-color: var(--crt-warning-bg);
      color: var(--crt-warning-text);
      border-color: var(--crt-warning-border);
    }

    /* Expired state - neutral appearance */
