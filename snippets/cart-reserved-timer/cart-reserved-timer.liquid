{% comment %}
  Cart Reserved Timer Snippet
  ==========================
  Creates urgency by displaying a countdown showing how long items are "reserved"
  in the customer's cart.
  
  Why this works:
  - Psychological urgency increases conversion rates
  - Perceived scarcity motivates faster checkout
  - Countdown creates a "deadline" that reduces procrastination
  
  Usage:
    {% render 'cart-reserved-timer' %}
    {% render 'cart-reserved-timer', duration_minutes: 15, style: 'prominent' %}
  
  @param {Number} duration_minutes - Countdown time in minutes (default: 10)
  @param {Number} warning_threshold - Seconds before warning state (default: 120)
  @param {Boolean} persist_timer - Save state in localStorage (default: true)
  @param {Boolean} show_icon - Show clock icon (default: true)
  @param {String} expired_action - Action on expire: 'message', 'redirect', 'refresh', 'hide' (default: 'message')
  @param {String} redirect_url - URL for redirect action (default: '/cart')
  @param {String} position - Layout: 'default', 'drawer', 'sticky' (default: 'default')
  @param {String} style - Visual style: 'default', 'minimal', 'prominent' (default: 'default')
  @param {Boolean} show_on_empty_cart - Show when cart is empty (default: false)
  @param {Boolean} reset_on_cart_update - Reset timer on cart changes (default: true)
  @param {String} custom_class - Additional CSS class (default: '')
{% endcomment %}

{%- comment %} Parameter defaults with fallbacks {% endcomment -%}
{%- liquid
  assign duration_minutes = duration_minutes | default: 10
  assign warning_threshold = warning_threshold | default: 120
  assign persist_timer = persist_timer | default: true
  assign show_icon = show_icon | default: true
  assign expired_action = expired_action | default: 'message'
  assign redirect_url = redirect_url | default: '/cart'
  assign position = position | default: 'default'
  assign style = style | default: 'default'
  assign show_on_empty_cart = show_on_empty_cart | default: false
  assign reset_on_cart_update = reset_on_cart_update | default: true
  assign custom_class = custom_class | default: ''
  
  # Calculate total seconds for JavaScript
  assign total_seconds = duration_minutes | times: 60
  
  # Determine if we should show the timer
  assign show_timer = true
  if cart.item_count == 0 and show_on_empty_cart == false
    assign show_timer = false
  endif
  
  # Build CSS class string based on parameters
  assign base_class = 'cart-reserved-timer'
  assign position_class = base_class | append: '--' | append: position
  assign style_class = base_class | append: '--' | append: style
-%}

