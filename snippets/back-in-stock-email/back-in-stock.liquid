{% comment %}
  Back-in-Stock Email Capture
  ────────────────────────────
  Usage: {% render 'back-in-stock', product: product %}

  Renders an email capture form when all variants are sold out.
  Uses Shopify's native contact form — no third-party app needed.
{% endcomment %}

{%- unless product.available -%}
  <div class="back-in-stock-form" id="back-in-stock-{{ product.id }}">
    <p class="back-in-stock-label">
      <strong>Out of stock.</strong> Enter your email and we'll notify you when it's back.
    </p>

    {%- form 'contact', id: 'back-in-stock-form' -%}
      <input type="hidden" name="contact[subject]"
             value="Back in Stock Request: {{ product.title | escape }}">
      <input type="hidden" name="contact[body]"
             value="Product URL: {{ shop.url }}{{ product.url }}">

      <div class="back-in-stock-fields">
        <label for="back-in-stock-email-{{ product.id }}" class="visually-hidden">
          Email address
        </label>
        <input
          type="email"
          id="back-in-stock-email-{{ product.id }}"
          name="contact[email]"
          placeholder="your@email.com"
          required
          autocomplete="email"
          class="back-in-stock-input"
        >
        <button type="submit" class="back-in-stock-btn">
          Notify Me
        </button>
      </div>

      {%- if form.posted_successfully? -%}
        <p class="back-in-stock-success">
          ✓ You're on the list! We'll email you when this is back in stock.
        </p>
      {%- endif -%}
    {%- endform -%}
  </div>
{%- endunless -%}

<style>
  .back-in-stock-form { margin-top: 1rem; }
  .back-in-stock-label { margin-bottom: 0.75rem; font-size: 0.9rem; }
  .back-in-stock-fields { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .back-in-stock-input {
    flex: 1; min-width: 200px; padding: 0.6rem 0.8rem;
    border: 1px solid #d1d5db; border-radius: 4px; font-size: 0.9rem;
  }
  .back-in-stock-btn {
    padding: 0.6rem 1.2rem; background: #111; color: #fff;
    border: none; border-radius: 4px; cursor: pointer; font-size: 0.9rem;
  }
  .back-in-stock-btn:hover { background: #333; }
  .back-in-stock-success { color: #16a34a; margin-top: 0.5rem; font-size: 0.9rem; }
</style>
