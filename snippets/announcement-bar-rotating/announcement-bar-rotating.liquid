{%- comment -%}
  Rotating Announcement Bar
  
  A production-ready announcement bar that cycles through multiple messages
  with smooth transitions and full accessibility support.
  
  @param {string} messages - Messages separated by | character
  @param {number} rotation_speed - Milliseconds between rotations (default: 4000)
  @param {string} background_color - Bar background color (default: #2c2c2c)
  @param {string} text_color - Text color (default: #ffffff)
  @param {boolean} show_close_button - Show dismiss button (default: true)
  @param {string} link_url - Optional URL for message links
  @param {boolean} pause_on_hover - Pause rotation on hover (default: true)
  @param {boolean} show_navigation - Show dot indicators (default: true)
  @param {string} transition_style - Animation: fade, slide, slide-left (default: fade)
  @param {number} cookie_days - Days to persist dismissed state (default: 1)
  @param {string} bar_id - Unique identifier for multiple bars (default: main)
{%- endcomment -%}

{%- liquid
  # Set defaults using Liquid's default filter
  # This ensures the component works even with minimal configuration
  assign messages = messages | default: ''
  assign rotation_speed = rotation_speed | default: 4000
  assign background_color = background_color | default: '#2c2c2c'
  assign text_color = text_color | default: '#ffffff'
  assign show_close_button = show_close_button | default: true
  assign pause_on_hover = pause_on_hover | default: true
  assign show_navigation = show_navigation | default: true
  assign transition_style = transition_style | default: 'fade'
  assign cookie_days = cookie_days | default: 1
  assign bar_id = bar_id | default: 'main'
  
  # Generate unique ID for this instance
  # Important for multiple announcement bars on same page
  assign unique_id = 'announcement-bar-' | append: bar_id
  assign cookie_name = 'announcement_dismissed_' | append: bar_id
  
  # Parse messages by splitting on pipe character
  # Trim whitespace from each message for clean display
  assign messages_array = messages | split: '|'
  assign message_count = messages_array.size
  
  # Exit early if no messages provided
  if message_count == 0 or messages == blank
    break
  endif
  
