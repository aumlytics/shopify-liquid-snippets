   * Each style has enter and exit states
   */
  
  /* Fade transition (default) */
  #{{ unique_id }}[data-transition="fade"] .rab__message {
    transform: none;
  }

  /* Slide up transition */
  #{{ unique_id }}[data-transition="slide"] .rab__message {
    transform: translateY(100%);
  }
  
  #{{ unique_id }}[data-transition="slide"] .rab__message--active {
    transform: translateY(0);
  }
  
  #{{ unique_id }}[data-transition="slide"] .rab__message--exit {
    transform: translateY(-100%);
  }

  /* Slide left transition */
  #{{ unique_id }}[data-transition="slide-left"] .rab__message {
    transform: translateX(100%);
  }
  
  #{{ unique_id }}[data-transition="slide-left"] .rab__message--active {
    transform: translateX(0);
  }
  
  #{{ unique_id }}[data-transition="slide-left"] .rab__message--exit {
    transform: translateX(-100%);
  }

