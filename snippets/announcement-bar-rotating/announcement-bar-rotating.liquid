  }

  /* First message visible by default (no-JS fallback) */
  #{{ unique_id }} .rab__message:first-child {
    position: relative;
  }

  /* Active message state */
  #{{ unique_id }} .rab__message--active {
    opacity: 1;
    visibility: visible;
    position: relative;
  }

  /*
