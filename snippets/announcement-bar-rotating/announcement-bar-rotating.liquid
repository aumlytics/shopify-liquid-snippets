    --rab-text-color: {{ text_color }};
    --rab-transition-duration: 0.4s;
    --rab-bar-height: 44px;
    --rab-font-size: 14px;
  }

  /*
   * Base bar styles
   * Using position relative for absolute positioned children
   */
  #{{ unique_id }}.rotating-announcement-bar {
    position: relative;
    width: 100%;
    background-color: var(--rab-bg-color);
    color: var(--rab-text-color);
    font-size: var(--rab-font-size);
    line-height: 1.4;
    z-index: 100;
    overflow: hidden;
  }

  /*
   * Hidden state - maintains DOM presence for accessibility
   * Using max-height transition for smooth collapse
   */
  #{{ unique_id }}.rotating-announcement-bar--hidden {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    transition: max-height 0.3s ease-out, opacity 0.2s ease-out;
