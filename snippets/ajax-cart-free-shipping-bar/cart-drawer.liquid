{% comment %}
  AJAX Cart Drawer + Free Shipping Bar
  ─────────────────────────────────────
  Add to layout/theme.liquid before </body>:
    {% render 'cart-drawer' %}
    {{ 'cart-drawer.js' | asset_url | script_tag }}
  Add data-open-cart to your ATC button to trigger the drawer.
{% endcomment %}

<div id="CartDrawerOverlay" class="cart-drawer-overlay" aria-hidden="true"></div>

<div
  id="CartDrawer"
  class="cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
  aria-hidden="true"
>
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">Your Cart</h2>
    <button class="cart-drawer__close" id="CartDrawerClose" aria-label="Close cart">
      &times;
    </button>
  </div>

  <!-- Free Shipping Bar -->
  <div class="cart-drawer__shipping-bar" id="ShippingBar">
    <p class="shipping-bar__message" id="ShippingBarMsg"></p>
    <div class="shipping-bar__track">
      <div class="shipping-bar__fill" id="ShippingBarFill" style="width:0%"></div>
    </div>
  </div>

  <!-- Cart Items -->
  <div class="cart-drawer__items" id="CartItems"></div>

  <!-- Footer -->
  <div class="cart-drawer__footer">
    <div class="cart-drawer__subtotal">
      <span>Subtotal</span>
      <span id="CartSubtotal"></span>
    </div>
    <a href="/checkout" class="cart-drawer__checkout-btn">Checkout</a>
    <a href="/cart" class="cart-drawer__view-cart">View full cart</a>
  </div>
</div>

<style>
  .cart-drawer-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 299;
    opacity: 0; pointer-events: none; transition: opacity .25s;
  }
  .cart-drawer-overlay.is-open { opacity: 1; pointer-events: all; }

  .cart-drawer {
    position: fixed; top: 0; right: 0; bottom: 0; z-index: 300;
    width: min(400px, 100vw); background: #fff;
    display: flex; flex-direction: column;
    transform: translateX(100%); transition: transform .3s ease;
    box-shadow: -4px 0 20px rgba(0,0,0,.12);
  }
  .cart-drawer.is-open { transform: translateX(0); }

  .cart-drawer__header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem; border-bottom: 1px solid #e5e7eb;
  }
  .cart-drawer__title { font-size: 1.1rem; font-weight: 700; margin: 0; }
  .cart-drawer__close {
    background: none; border: none; font-size: 1.5rem;
    cursor: pointer; color: #374151; line-height: 1;
  }

  .cart-drawer__shipping-bar { padding: 0.75rem 1.25rem; background: #f9fafb; }
  .shipping-bar__message { font-size: 0.8rem; margin-bottom: 0.4rem; color: #374151; }
  .shipping-bar__track {
    height: 6px; background: #e5e7eb; border-radius: 99px; overflow: hidden;
  }
  .shipping-bar__fill {
    height: 100%; background: #16a34a; border-radius: 99px;
    transition: width .4s ease;
  }

  .cart-drawer__items {
    flex: 1; overflow-y: auto; padding: 1rem 1.25rem;
    display: flex; flex-direction: column; gap: 1rem;
  }

  .cart-item { display: flex; gap: 0.75rem; align-items: flex-start; }
  .cart-item__img { width: 64px; height: 64px; object-fit: cover; border-radius: 4px; }
  .cart-item__info { flex: 1; }
  .cart-item__title { font-size: 0.85rem; font-weight: 600; margin-bottom: 2px; }
  .cart-item__variant { font-size: 0.75rem; color: #6b7280; }
  .cart-item__price { font-size: 0.85rem; margin-top: 4px; }
  .cart-item__qty {
    display: flex; align-items: center; gap: 0.4rem; margin-top: 6px;
  }
  .cart-item__qty button {
    width: 24px; height: 24px; border: 1px solid #d1d5db; border-radius: 4px;
    background: none; cursor: pointer; font-size: 1rem; line-height: 1;
  }
  .cart-item__qty span { font-size: 0.85rem; min-width: 20px; text-align: center; }
  .cart-item__remove {
    background: none; border: none; color: #9ca3af;
    font-size: 0.75rem; cursor: pointer; margin-top: 4px;
  }
  .cart-item__remove:hover { color: #ef4444; }

  .cart-drawer__footer {
    padding: 1rem 1.25rem; border-top: 1px solid #e5e7eb;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .cart-drawer__subtotal {
    display: flex; justify-content: space-between;
    font-weight: 700; font-size: 1rem;
  }
  .cart-drawer__checkout-btn {
    display: block; text-align: center; background: #111; color: #fff;
    padding: 0.75rem; border-radius: 4px; text-decoration: none;
    font-weight: 600; font-size: 0.95rem;
  }
  .cart-drawer__checkout-btn:hover { background: #333; }
  .cart-drawer__view-cart {
    text-align: center; font-size: 0.8rem; color: #6b7280;
    text-decoration: underline;
  }
  .cart-drawer-empty { text-align: center; color: #6b7280; padding: 2rem 0; }
</style>
