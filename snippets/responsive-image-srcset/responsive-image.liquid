{% comment %}
  Responsive Image with srcset
  ─────────────────────────────
  Usage:
    {% render 'responsive-image',
      image: product.featured_image,
      sizes: '(min-width: 768px) 50vw, 100vw',
      alt: product.title,
      loading: 'lazy',
      class: 'product-image'
    %}
{% endcomment %}

{%- liquid
  assign img     = image
  assign img_alt = alt | default: img.alt | escape
  assign img_loading = loading | default: 'lazy'
  assign img_class   = class | default: ''
  assign img_sizes   = sizes | default: '100vw'

  # Width breakpoints — covers mobile through retina desktop
  assign widths = '360,540,720,900,1200,1800'
  assign width_array = widths | split: ','
-%}

{%- if img != blank -%}
  <img
    src="{{ img | image_url: width: 720 }}"
    srcset="
      {%- for w in width_array -%}
        {{ img | image_url: width: w }} {{ w }}w
        {%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    "
    sizes="{{ img_sizes }}"
    alt="{{ img_alt }}"
    width="{{ img.width }}"
    height="{{ img.height }}"
    loading="{{ img_loading }}"
    {%- if img_loading == 'eager' %} fetchpriority="high"{%- endif %}
    {%- if img_class != '' %} class="{{ img_class }}"{%- endif %}
  >
{%- endif -%}
